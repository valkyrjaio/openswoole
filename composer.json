{
  "name"              : "valkyrja/openswoole",
  "type"              : "library",
  "description"       : "OpenSwoole persistent worker entry point for the Valkyrja Framework.",
  "homepage"          : "https://www.valkyrja.io",
  "keywords"          : [
    "framework",
    "valkyrja",
    "openswoole",
    "swoole",
    "worker"
  ],
  "license"           : "MIT",
  "authors"           : [
    {
      "name"  : "Melech Mizrachi",
      "email" : "melechmizrachi@gmail.com"
    }
  ],
  "require"           : {
    "php"               : ">=8.4",
    "ext-openswoole"    : ">=26.2.0",
    "openswoole/core"   : "^26.2.0",
    "valkyrja/valkyrja" : "^26.1.0"
  },
  "conflict"          : {
    "openswoole/core" : "<26.2.0"
  },
  "autoload"          : {
    "psr-4" : {
      "Valkyrja\\OpenSwoole\\" : "src/OpenSwoole"
    }
  },
  "autoload-dev"      : {
    "psr-4" : {
      "Valkyrja\\OpenSwoole\\Tests\\" : "tests/Tests"
    }
  },
  "minimum-stability" : "dev",
  "prefer-stable"     : true,
  "extra"             : {
    "branch-alias" : {
      "dev-master" : "26.x-dev"
    }
  }
}